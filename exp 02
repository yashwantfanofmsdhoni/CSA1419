#include <stdio.h>
#include <string.h>

int main() {
    char str[200];

    printf("Enter a line: ");
    fgets(str, sizeof(str), stdin);

    if (str[0] == '/' && str[1] == '/')
        printf("Single-line Comment\n");

    else if (str[0] == '/' && str[1] == '*') {
        if (strstr(str, "*/"))
            printf("Multi-line Comment\n");
        else
            printf("Invalid Multi-line Comment\n");
    }

    else
        printf("Not a Comment\n");

    return 0;
}
